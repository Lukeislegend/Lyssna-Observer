DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lyssna_observer?schema=public"

# LiveKit (https://cloud.livekit.io)
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Optional: RoomComposite egress (LiveKit Cloud egress must be enabled)
LIVEKIT_EGRESS_LAYOUT="speaker" # speaker | grid
EGRESS_S3_BUCKET=""
EGRESS_S3_ACCESS_KEY=""
EGRESS_S3_SECRET_KEY=""
EGRESS_S3_REGION=""

# Deepgram (optional — enables chunked transcription API)
DEEPGRAM_API_KEY=""

# Observer room optional shared PIN (if set, observers must send x-observer-passcode header or query)
OBSERVER_DEFAULT_PASSCODE=""

# App URL for generated links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
